    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 30, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 50 },
      "id": 41,
