      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 59 },
      "id": 51,
      "options": { "legend": { "displayMode": "table", "placement": "right", "sortBy": "Last *", "sortDesc": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Container Memory Usage",
      "type": "timeseries",
      "targets": [{
        "expr": "container_memory_usage_bytes{name!=\"\",name!~\"POD.*\"}",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 69 },
      "id": 52,
      "options": { "legend": { "displayMode": "table", "placement": "right", "sortBy": "Last *", "sortDesc": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Container Network RX",
      "type": "timeseries",
      "targets": [{
        "expr": "sum(rate(container_network_receive_bytes_total{name!=\"\",name!~\"POD.*\"}[5m])) by (name)",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 69 },
      "id": 53,
      "options": { "legend": { "displayMode": "table", "placement": "right", "sortBy": "Last *", "sortDesc": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Container Network TX",
      "type": "timeseries",
      "targets": [{
        "expr": "sum(rate(container_network_transmit_bytes_total{name!=\"\",name!~\"POD.*\"}[5m])) by (name)",
        "legendFormat": "{{name}}"
      }]
