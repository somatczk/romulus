# =============================================================================
# ZimaOS Docker Stack - Shared Environment Variables
# =============================================================================
# Copy this file to .env and replace all changeme_ values before deployment.
# =============================================================================

# --- System ---
PUID=999
PGID=1000
TZ=Europe/Budapest

# --- Domain ---
DOMAIN=romulus.hu

# --- Cloudflare ---
CF_API_TOKEN=changeme_cloudflare_api_token

# --- Storage Paths ---
SSD=/media/SSD-Storage
HDD=/media/HDD-Storage
APPDATA=/media/SSD-Storage/appdata

# --- Database Passwords ---
NEXTCLOUD_DB_PASSWORD=changeme_nextcloud_db
IMMICH_DB_PASSWORD=changeme_immich_db

# --- GitHub (CI/CD) ---
# PAT needs: admin:org scope (classic) or Organization → Self-hosted runners: Read & Write (fine-grained)
GITHUB_PAT=changeme_github_pat
GITHUB_ORG=changeme_github_org

# --- Redis ---
NEXTCLOUD_REDIS_PASSWORD=changeme_nextcloud_redis

# --- Backup ---
RESTIC_PASSWORD=changeme_restic_password

# --- Notifications ---
NTFY_BASE_URL=https://notify.romulus.hu
TELEGRAM_BOT_TOKEN=changeme_telegram_bot_token
TELEGRAM_CHAT_ID=changeme_telegram_chat_id

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=changeme_grafana_admin

# --- CrowdSec ---
CROWDSEC_BOUNCER_API_KEY=changeme_crowdsec_bouncer_key

# --- qBittorrent ---
QBIT_WEBUI_PASSWORD=changeme_qbit_password

# --- Speedtest Tracker ---
SPEEDTEST_APP_KEY=changeme_speedtest_app_key

# --- TeamSpeak ---
TEAMSPEAK_DB_PASSWORD=changeme_teamspeak_db

# --- Authelia ---
# Generate with: docker run authelia/authelia:latest authelia crypto rand --length 64 --charset alphanumeric
AUTHELIA_SESSION_SECRET=changeme_authelia_session
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme_authelia_storage
AUTHELIA_JWT_SECRET=changeme_authelia_jwt

# --- Paperless-ngx ---
PAPERLESS_DB_PASSWORD=changeme_paperless_db
PAPERLESS_SECRET_KEY=changeme_paperless_secret
PAPERLESS_ADMIN_PASSWORD=changeme_paperless_admin

# --- Hydra Trading ---
HYDRA_DB_PASSWORD=changeme_hydra_db
BINANCE_API_KEY=changeme_binance_api_key
BINANCE_API_SECRET=changeme_binance_api_secret
BYBIT_API_KEY=changeme_bybit_api_key
BYBIT_API_SECRET=changeme_bybit_api_secret
KRAKEN_API_KEY=changeme_kraken_api_key
KRAKEN_API_SECRET=changeme_kraken_api_secret
OKX_API_KEY=changeme_okx_api_key
OKX_API_SECRET=changeme_okx_api_secret
OKX_PASSPHRASE=changeme_okx_passphrase
HYDRA_TESTNET=true
HYDRA_TELEGRAM_BOT_TOKEN=changeme_hydra_telegram_bot_token
HYDRA_TELEGRAM_CHAT_ID=changeme_hydra_telegram_chat_id
