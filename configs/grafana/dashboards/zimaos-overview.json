  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "System Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "CPU",
      "type": "gauge",
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "Memory",
      "type": "gauge",
      "targets": [{ "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "RAM" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 6, "y": 1 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "Swap",
      "type": "gauge",
      "targets": [{ "expr": "(1 - node_memory_SwapFree_bytes / node_memory_SwapTotal_bytes) * 100", "legendFormat": "Swap" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 9, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "SSD",
      "type": "gauge",
      "targets": [{ "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/media/SSD-Storage\"} / node_filesystem_size_bytes{mountpoint=\"/media/SSD-Storage\"} * 100)", "legendFormat": "SSD" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "HDD",
      "type": "gauge",
      "targets": [{ "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/media/HDD-Storage\"} / node_filesystem_size_bytes{mountpoint=\"/media/HDD-Storage\"} * 100)", "legendFormat": "HDD" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 15, "y": 1 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "GPU VRAM",
      "type": "gauge",
      "targets": [{ "expr": "nvidia_smi_memory_used_bytes / nvidia_smi_memory_total_bytes * 100", "legendFormat": "VRAM" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 18, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background", "justifyMode": "auto", "textMode": "value_and_name", "wideLayout": true },
      "title": "Temps",
      "type": "stat",
      "targets": [
        { "expr": "node_hwmon_temp_celsius{chip=~\".*k10temp.*\"}", "legendFormat": "CPU" },
        { "expr": "nvidia_smi_temperature_gpu", "legendFormat": "GPU" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 3, "x": 21, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value", "justifyMode": "auto", "textMode": "value", "wideLayout": true },
      "title": "Uptime",
      "type": "stat",
      "targets": [{ "expr": "node_time_seconds - node_boot_time_seconds", "legendFormat": "Uptime" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "CPU & Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 20, "lineWidth": 2, "spanNulls": false } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "Total CPU" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\"}[5m])) * 100", "legendFormat": "User" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\"}[5m])) * 100", "legendFormat": "System" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100", "legendFormat": "IOWait" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used" },
        { "expr": "node_memory_Cached_bytes", "legendFormat": "Cached" },
        { "expr": "node_memory_Buffers_bytes", "legendFormat": "Buffers" },
        { "expr": "node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes", "legendFormat": "Swap Used" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "System Load Average",
      "type": "timeseries",
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m" },
        { "expr": "node_load5", "legendFormat": "5m" },
        { "expr": "node_load15", "legendFormat": "15m" },
        { "expr": "count(node_cpu_seconds_total{mode=\"idle\"})", "legendFormat": "CPU Cores" }
      ]
    },

