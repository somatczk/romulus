      "title": "Container CPU Usage",
      "type": "timeseries",
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\",name!~\"POD.*\"}[5m])) by (name) * 100",
        "legendFormat": "{{name}}"
