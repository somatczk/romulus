    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 77 },
      "id": 106,
      "title": "Traefik",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 78 },
      "id": 60,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Traefik Request Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(traefik_service_requests_total[5m])) by (service)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 78 },
      "id": 61,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Traefik Response Time (avg)",
