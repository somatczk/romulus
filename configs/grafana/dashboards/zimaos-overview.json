      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device=~\"eth.*|enp.*\"}[5m]) * 8", "legendFormat": "{{device}} RX" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Network Transmitted",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_network_transmit_bytes_total{device=~\"eth.*|enp.*\"}[5m]) * 8", "legendFormat": "{{device}} TX" }
      ]
