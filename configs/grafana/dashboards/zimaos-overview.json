        { "expr": "nvidia_smi_memory_total_bytes", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "celsius", "min": 20, "max": 100, "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]}
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 50 },
      "id": 42,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "GPU Temperature",
      "type": "timeseries",
      "targets": [
        { "expr": "nvidia_smi_temperature_gpu", "legendFormat": "GPU Temp" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "watt", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 50 },
      "id": 43,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "GPU Power Draw",
